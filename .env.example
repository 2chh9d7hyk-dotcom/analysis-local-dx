# ──────────────────────────────────────────────────────────────
# 大玉村 × NES EBPM ダッシュボード — APIキー設定テンプレート
# このファイルを .env にコピーして実際のキーを記入してください
# .env は .gitignore に追加し、絶対にリポジトリにコミットしないこと
# ──────────────────────────────────────────────────────────────

# ── RESAS (地域経済分析システム) ──────────────────────────────
# 取得先: https://opendata.resas-portal.go.jp/
# 人口構成・産業構造・社会増減データを自動取得できます
RESAS_API_KEY=your_resas_api_key_here

# ── e-Stat (政府統計の総合窓口) ──────────────────────────────
# 取得先: https://www.e-stat.go.jp/api/
# 国勢調査・住民基本台帳などの統計データを取得できます
ESTAT_API_KEY=your_estat_api_key_here
